{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "simplePage": {
      "type": "component",
      "component": "pages.simpe-page",
      "repeatable": false
    },
    "title": {
      "type": "string",
      "required": true
    },
    "pageWithBlocks": {
      "type": "component",
      "component": "pages.page-with-blocks",
      "repeatable": false
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false,
      "required": true
    },
    "url": {
      "type": "uid",
      "targetField": "title",
      "required": false
    },
    "specialisations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::specialisation.specialisation",
      "mappedBy": "pages"
    }
  }
}
